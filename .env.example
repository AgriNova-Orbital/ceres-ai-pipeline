# Earth Engine API Configuration
# Copy this file to .env and fill in your credentials

# Google Earth Engine Project ID (required)
EE_PROJECT=your-earth-engine-project-id

# Google API Key (optional)
GOOGLE_API_KEY=your-google-api-key

# Docker container runtime UID/GID (recommended for bind-mounted file ownership)
LOCAL_UID=1000
LOCAL_GID=1000

# Sentry (optional)
# Use SENTRY_DSN for Flask/RQ and NEXT_PUBLIC_SENTRY_DSN for browser-side Next.js.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=local
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false

# Sentry source map upload during frontend builds (optional CI-only values)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# New Relic Python APM (optional)
# Web and worker containers only wrap with newrelic-admin when both key/name exist.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=Ceres API Dev
NEW_RELIC_WORKER_APP_NAME=Ceres Worker Dev
NEW_RELIC_LOG=stdout
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# Clerk authentication (required for frontend auth once enabled)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
CLERK_JWKS_URL=

# Path to Service Account JSON (optional)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Default Area of Interest (bounding box: lon_min,lat_min,lon_max,lat_max)
DEFAULT_AOI=-122.5,37.7,-122.0,37.9

# Default date range (update to current dates as needed)
DEFAULT_START_DATE=2024-01-01
DEFAULT_END_DATE=2024-12-31

# Maximum cloud cover percentage (0-100)
MAX_CLOUD_COVER=20

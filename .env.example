# Earth Engine API Configuration
# Copy this file to .env and fill in your credentials

# Google Earth Engine Project ID (required)
EE_PROJECT=your-earth-engine-project-id

# Google API Key (optional)
GOOGLE_API_KEY=your-google-api-key

# Path to Service Account JSON (optional)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Default Area of Interest (bounding box: lon_min,lat_min,lon_max,lat_max)
DEFAULT_AOI=-122.5,37.7,-122.0,37.9

# Default date range (update to current dates as needed)
DEFAULT_START_DATE=2024-01-01
DEFAULT_END_DATE=2024-12-31

# Maximum cloud cover percentage (0-100)
MAX_CLOUD_COVER=20
